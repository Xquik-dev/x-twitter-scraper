{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.xquik/mcp",
  "description": "X data platform with 100+ REST endpoints, 2 MCP tools, 23 extraction tools, webhooks, and confirmation-gated writes.",
  "repository": {
    "url": "https://github.com/Xquik-dev/x-twitter-scraper",
    "source": "github"
  },
  "version": "2.4.9",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://xquik.com/mcp",
      "headers": [
        {
          "name": "x-api-key",
          "value": "{XQUIK_API_KEY}",
          "description": "Xquik API key from https://dashboard.xquik.com/account",
          "isRequired": true,
          "isSecret": true,
          "variables": {
            "XQUIK_API_KEY": {
              "description": "Your Xquik API key (starts with xq_)",
              "isSecret": true
            }
          }
        }
      ]
    }
  ]
}
